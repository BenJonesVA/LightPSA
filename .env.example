DATABASE_URL="postgresql://psa:psa@localhost:5432/psa?schema=public"
AUTH_SECRET="dev-only-secret-replace-with-openssl-rand-base64-32"

# Bearer secret checked by app/api/cron/* route handlers (lib/cron-auth.ts).
# Required for the idle-time-automation and SLA-breach-alert sweeps to run at
# all — with no value set, every request to those routes is rejected.
CRON_SECRET="replace-with-a-random-secret"

# Outbound email (Resend). Both must be set for real sends; without them,
# SEND_EMAIL_NOTIFICATION and SLA breach alerts fall back to writing an
# internal comment explaining that no provider is configured (see lib/email.ts).
RESEND_API_KEY=""
EMAIL_FROM="PSA <notifications@yourdomain.com>"

# Base URL used to build absolute links in outbound emails (currently just
# the CSAT survey link). Defaults to the local dev server if unset.
APP_URL="http://localhost:3131"
