DATABASE_URL="postgresql://psa:psa@localhost:5432/psa?schema=public"
AUTH_SECRET="dev-only-secret-replace-with-openssl-rand-base64-32"

# Postgres credentials used by docker-compose.yml (interpolated into the
# compose file itself, not just passed into containers) — default to the
# dev-only psa/psa if unset. Set real values before deploying anywhere real.
POSTGRES_USER="psa"
POSTGRES_PASSWORD="psa"
POSTGRES_DB="psa"

# Required in production, whenever the app runs behind a reverse proxy
# (Nginx Proxy Manager on a self-hosted VM, or anything else) rather than
# being hit directly. Auth.js v5 rejects requests with an "UntrustedHost"
# error unless told to trust the Host/X-Forwarded-* headers the proxy sets.
# Vercel sets this automatically; a self-hosted VM must set it explicitly.
AUTH_TRUST_HOST="true"

# Bearer secret checked by app/api/cron/* route handlers (lib/cron-auth.ts).
# Required for the idle-time-automation and SLA-breach-alert sweeps to run at
# all — with no value set, every request to those routes is rejected.
CRON_SECRET="replace-with-a-random-secret"

# Outbound email (Resend). Both must be set for real sends; without them,
# SEND_EMAIL_NOTIFICATION and SLA breach alerts fall back to writing an
# internal comment explaining that no provider is configured (see lib/email.ts).
RESEND_API_KEY=""
EMAIL_FROM="PSA <notifications@yourdomain.com>"

# Base URL used to build absolute links in outbound emails (currently just
# the CSAT survey link). Defaults to the local dev server if unset. On the
# self-hosted VM path, set this to https://<APP_DOMAIN>.
APP_URL="http://localhost:3131"

# Inbound email-to-ticket (app/api/inbound-email/route.ts). Configure a
# Postmark inbound server pointed at your receiving domain, with its webhook
# URL set to https://yourapp.com/api/inbound-email?token=<INBOUND_EMAIL_SECRET>.
# Without INBOUND_EMAIL_SECRET set, every request to that route is rejected.
INBOUND_EMAIL_SECRET="replace-with-a-random-secret"

# The domain mail should be sent to for it to land back on the right ticket
# (ticket-{id}@<this domain>) — must match whatever domain you point at
# Postmark's inbound server. Without this set, outbound client notification
# emails have no Reply-To, so a client's reply just goes to EMAIL_FROM
# instead of appending to the ticket.
INBOUND_EMAIL_DOMAIN=""
